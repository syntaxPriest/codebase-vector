{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Codebase Vector Bridge",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/extension"],
      "outFiles": ["${workspaceFolder}/extension/out/**/*.js"],
      "sourceMaps": true,
      "preLaunchTask": "npm: compile - extension"
    },
    {
      "name": "Run Codebase Vector Bridge (watch)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/extension"],
      "outFiles": ["${workspaceFolder}/extension/out/**/*.js"],
      "sourceMaps": true,
      "preLaunchTask": "npm: watch - extension"
    }
  ]
}
